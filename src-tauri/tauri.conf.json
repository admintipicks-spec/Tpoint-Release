{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "T-Point",
  "version": "0.1.10",
  "identifier": "com.masterflow.tpoint",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "여기! 교실 주목 효과 위젯",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "maximized": true,
        "visible": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/1TEST-1234",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFNEM5NkNBREI1NkMyRDYKUldUV3dsYmJ5cFpNcmdHQUFGRlM5WU9nNG01VWN6T21KbVBadE5heTFGOGpXalI2K2RzZjMrbXUK",
      "endpoints": [
        "https://github.com/admintipicks-spec/Tpoint-Release/releases/latest/download/latest.json"
      ]
    }
  }
}
